# Copy to .env and point this at your existing Switch title folder on the host.
# Mounted read-write into the container at /titles, since Library Scan's
# "Organize" feature renames/moves files there.
TITLES_HOST_DIR=/path/to/your/titles

# Optional: turns on the Staging page/API. Defaults to false (off, and the
# Staging nav link/page are hidden) so this is entirely opt-in.
STAGING_ENABLED=false

# Only used when STAGING_ENABLED=true above: a separate drop-off folder for
# new files. Point it at an empty folder (or your downloads folder) on the
# host — the Staging page scans and matches files here, and moving accepted
# files renames them into TITLES_HOST_DIR above. Mounted read-write for the
# same reason.
STAGING_HOST_DIR=/path/to/your/staging
